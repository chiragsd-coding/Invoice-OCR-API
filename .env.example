# App
APP_BASE_URL=http://localhost:8000
JWT_SECRET=change_me_to_a_random_secret

# Active gateway: "razorpay" | "cashfree"
ACTIVE_GATEWAY=razorpay

# Razorpay (primary gateway)
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Set in Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Subscription Plan IDs
# Create in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_STARTER_PLAN_ID=plan_...
RAZORPAY_PRO_PLAN_ID=plan_...

# Cashfree (secondary / fallback gateway)
# Get from https://merchant.cashfree.com/merchants/developer
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=TEST
CASHFREE_STARTER_PLAN_ID=
CASHFREE_PRO_PLAN_ID=
